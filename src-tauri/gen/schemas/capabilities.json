{
  "default": {
    "identifier": "default",
    "description": "Minimal capability for Ambient Glass's single trusted overlay window.",
    "local": true,
    "windows": ["main"],
    "permissions": [
      "core:default",
      "allow-get-wallpaper-engine-status",
      "allow-configure-wallpaper-engine",
      "allow-apply-wallpaper-scene",
      "allow-test-wallpaper-scene",
      "allow-get-github-commits",
      "allow-refresh-sports",
      "allow-transcribe-audio",
      "allow-save-provider-secret",
      "allow-delete-provider-secret",
      "allow-get-secure-token-storage-status",
      "allow-begin-google-calendar-oauth",
      "allow-complete-google-calendar-oauth",
      "allow-disconnect-google-calendar",
      "allow-get-google-calendar-today",
      "allow-create-google-calendar-event",
      "allow-list-native-alarms",
      "allow-get-native-alarm-scheduler-status",
      "allow-schedule-native-alarm",
      "allow-snooze-native-alarm",
      "allow-dismiss-native-alarm",
      "allow-test-native-alarm",
      "allow-mark-overlay-ready",
      "allow-set-display-window-mode",
      "allow-quit-application",
      "allow-get-display-window-state",
      "allow-get-display-monitors",
      "allow-set-display-monitor",
      "store:allow-load",
      "store:allow-get",
      "store:allow-set",
      "store:allow-save",
      "autostart:allow-enable",
      "autostart:allow-disable",
      "autostart:allow-is-enabled",
      "notification:allow-is-permission-granted",
      "notification:allow-request-permission",
      "notification:allow-notify",
      {
        "identifier": "opener:allow-open-url",
        "allow": [{ "url": "https://accounts.google.com/**" }]
      }
    ]
  }
}
