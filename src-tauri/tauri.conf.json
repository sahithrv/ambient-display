{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ambient Glass",
  "version": "0.1.0",
  "identifier": "io.ambientglass.display",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:4173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Ambient Glass",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": true,
        "shadow": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": false,
        "focus": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:4173 ws://localhost:4173 https://api.open-meteo.com https://api.github.com https://www.thesportsdb.com; img-src 'self' asset: http://asset.localhost data: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; media-src 'self' asset: http://asset.localhost; script-src 'self';",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPLOCALDATA/wallpapers/*/media.jpg",
          "$APPLOCALDATA/wallpapers/*/media.png",
          "$APPLOCALDATA/wallpapers/*/media.webp",
          "$APPLOCALDATA/wallpapers/*/media.mp4",
          "$APPLOCALDATA/wallpapers/*/media.webm"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
